{
  "manifest_version": 3,
  "name": "IPGate TPE Bot",
  "version": "2.2",
  "description": "TPE verilerini arka planda çeker.",
  "permissions": [
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.turkpatent.gov.tr/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.turkpatent.gov.tr/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://*.turkpatent.gov.tr/*"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://*.web.app/*",
      "https://*.firebaseapp.com/*",
      "https://ipgate.evrekagroup.com/*"
    ]
  }
}