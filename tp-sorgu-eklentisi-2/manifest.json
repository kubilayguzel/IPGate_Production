{
  "manifest_version": 3,
  "name": "Evreka IP - TÜRKPATENT Sorgu Yardımcısı",
  "version": "2.2.11",
  "description": "Evreka IP uygulamasından TÜRKPATENT üzerinde otomatik sorgulama yapar.",
  "permissions": [],
  "host_permissions": [
    "*://arastirma.turkpatent.gov.tr/*",
    "*://webim.turkpatent.gov.tr/*",
    "*://www.turkpatent.gov.tr/*",
    "*://opts.turkpatent.gov.tr/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.turkpatent.gov.tr/arastirma-yap*",
        "*://opts.turkpatent.gov.tr/*"
      ],
      "js": [
        "content_script.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://kubilayguzel.github.io/*",
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://ip-manager-production-aab4b.web.app/*",
      "https://ip-manager-production-aab4b.firebaseapp.com/*",
      "https://ipgate-31bd2.web.app/*",
      "https://ipgate-31bd2.firebaseapp.com/*",
      "https://ipgate.evrekagroup.com/*",
      "https://ipgate-supa-test.web.app/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://*.turkpatent.gov.tr/*"]
    }
  ]
}