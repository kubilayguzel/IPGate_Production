{
  "manifest_version": 3,
  "name": "IPGate Bülten Robotu (API Fetcher)",
  "version": "2.0.0",
  "description": "TürkPatent arka plan API'sini kullanarak e-Devlet oturumu üzerinden sessiz ve hızlı veri çeker.",
  "host_permissions": [
    "*://opts.turkpatent.gov.tr/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://opts.turkpatent.gov.tr/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://kubilayguzel.github.io/*",
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://ip-manager-production-aab4b.web.app/*",
      "https://ip-manager-production-aab4b.firebaseapp.com/*",
      "https://ipgate-31bd2.web.app/*",
      "https://ipgate-31bd2.firebaseapp.com/*"
    ]
  }
}